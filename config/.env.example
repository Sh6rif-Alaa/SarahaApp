PORT=your_port
DATABASE_URL=your_mongodb
TOKEN_KEY=your_jwt_key_access_token
REFRESH_TOKEN_KEY=your_jwt_key_refresh_token
ENCRYPT_KEY==your_encrypt_key
ENCRYPT_ALGORITHM=your_algorithm like (aes-256-cbc)
PREFIX=your_prefix
SALT_ROUNDS=your_salt
CLIENT_ID=your_client_id
CLOUD_NAME= your_client_cloud_name,
API_KEY= your_client_cloud_api_key,
API_SECRET= your_client_cloud_api_secret